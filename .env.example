CITY=Munich
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
OVERPASS_BASE_URL=https://overpass-api.de/api/interpreter
WALKING_ROUTER_BASE_URL=https://router.project-osrm.org
TRANSIT_MODE=heuristic
TRANSIT_BASE_URL=
JAWG_API=
JAWG_STYLE_ID=jawg-streets

APP_DOMAIN=rokum.example.com
APP_VERSION=latest
BASIC_AUTH_USER=rokum
# Generate with:
# docker run --rm httpd:2.4-alpine htpasswd -nbB rokum 'change-me' | cut -d: -f2-
# Keep the bcrypt hash single-quoted so Compose does not expand its dollar signs.
BASIC_AUTH_HASH='replace-with-bcrypt-hash'
